{
  "name": "file-insights",
  "displayName": "File Insights",
  "description": "Display file size in status bar with automatic formatting and advanced metrics",
  "version": "2.0.0",
  "publisher": "anomalyco",
  "engines": {
    "vscode": "^1.102.0",
    "node": ">=20.0.0"
  },
  "icon": "resources/icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "file",
    "size",
    "insights",
    "metadata",
    "encoding",
    "line count",
    "character count"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fileInsights.enable",
        "title": "File Insights: Enable",
        "category": "File Insights"
      },
      {
        "command": "fileInsights.disable",
        "title": "File Insights: Disable",
        "category": "File Insights"
      },
      {
        "command": "fileInsights.exportSettings",
        "title": "File Insights: Export Settings",
        "category": "File Insights"
      },
      {
        "command": "fileInsights.importSettings",
        "title": "File Insights: Import Settings",
        "category": "File Insights"
      }
    ],
    "configuration": {
      "title": "File Insights",
      "properties": {
        "fileInsights.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable File Insights extension"
        },
        "fileInsights.displayFormat": {
          "type": "string",
          "enum": [
            "auto",
            "bytes",
            "kb",
            "mb",
            "gb"
          ],
          "default": "auto",
          "description": "Format for displaying file sizes",
          "enumDescriptions": [
            "Automatically choose best format",
            "Always show in bytes",
            "Always show in kilobytes",
            "Always show in megabytes",
            "Always show in gigabytes"
          ]
        },
        "fileInsights.colorCoding.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable color coding based on file size"
        },
        "fileInsights.colorCoding.thresholds.yellow": {
          "type": "string",
          "default": "100KB",
          "description": "File size threshold for yellow color (e.g., '100KB')"
        },
        "fileInsights.colorCoding.thresholds.orange": {
          "type": "string",
          "default": "1MB",
          "description": "File size threshold for orange level"
        },
        "fileInsights.colorCoding.thresholds.red": {
          "type": "string",
          "default": "10MB",
          "description": "File size threshold for red level"
        },
        "fileInsights.colorCoding.colors.green": {
          "type": "string",
          "default": "terminal.ansiGreen",
          "description": "Theme color for small files (green)"
        },
        "fileInsights.colorCoding.colors.yellow": {
          "type": "string",
          "default": "terminal.ansiYellow",
          "description": "Theme color for medium files (yellow)"
        },
        "fileInsights.colorCoding.colors.orange": {
          "type": "string",
          "default": "statusBarItem.warningForeground",
          "description": "Theme color for large files (orange)"
        },
        "fileInsights.colorCoding.colors.red": {
          "type": "string",
          "default": "errorForeground",
          "description": "theme color for very large files (red)"
        },
        "fileInsights.statusBar.alignment": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "right",
          "description": "Status bar alignment (left or right)"
        },
        "fileInsights.statusBar.priority": {
          "type": "number",
          "default": 0,
          "description": "Status bar priority (higher numbers appear first)"
        },
        "fileInsights.statusBar.hideIfExceeds": {
          "type": "boolean",
          "default": false,
          "description": "Hide status bar if file exceeds threshold"
        },
        "fileInsights.statusBar.hideThreshold": {
          "type": "string",
          "default": "100MB",
          "description": "File size threshold for hiding status bar (e.g., '100MB')"
        },
        "fileInsights.metadataDisplay.showLineCount": {
          "type": "boolean",
          "default": true,
          "description": "Show line count in tooltip"
        },
        "fileInsights.metadataDisplay.showCharacterCount": {
          "type": "boolean",
          "default": true,
          "description": "Show character count in tooltip"
        },
        "fileInsights.metadataDisplay.showEncoding": {
          "type": "boolean",
          "default": true,
          "description": "Show file encoding in tooltip"
        },
        "fileInsights.metadataDisplay.showFileType": {
          "type": "boolean",
          "default": true,
          "description": "Show file type extension in tooltip"
        },
        "fileInsights.metadataDisplay.showRelativePath": {
          "type": "boolean",
          "default": true,
          "description": "Show relative path in tooltip"
        },
        "fileInsights.sizeWarnings.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable size warnings"
        },
        "fileInsights.sizeWarnings.thresholds.yellow": {
          "type": "string",
          "default": "100KB",
          "description": "Warning threshold for yellow level (e.g., '100KB')"
        },
        "fileInsights.sizeWarnings.thresholds.orange": {
          "type": "string",
          "default": "1MB",
          "description": "Warning threshold for orange level"
        },
        "fileInsights.sizeWarnings.thresholds.red": {
          "type": "string",
          "default": "10MB",
          "description": "Warning threshold for red level"
        },
        "fileInsights.sizeWarnings.notificationFrequency": {
          "type": "string",
          "enum": [
            "once",
            "always",
            "daily"
          ],
          "default": "always",
          "description": "How often to show warnings",
          "enumDescriptions": [
            "Warn once per file",
            "Always warn when opening file",
            "Warn at most once per day"
          ]
        },
        "fileInsights.sizeWarnings.showNotification": {
          "type": "boolean",
          "default": true,
          "description": "Show notification for size warnings"
        },
        "fileInsights.deltaDisplay.showDeltaIndicator": {
          "type": "boolean",
          "default": true,
          "description": "Show delta indicator (↑) in status bar"
        },
        "fileInsights.deltaDisplay.showDeltaInTooltip": {
          "type": "boolean",
          "default": true,
          "description": "Show delta information in tooltip"
        }
      }
    }
  },
  "vsce": {
    "baseImageUrl": "./logo.png",
    "dependencies": true
  },
  "scripts": {
    "vscode:prepublish": "tsx esbuild.config.ts --production",
    "build": "tsx esbuild.config.ts",
    "watch": "tsx esbuild.config.ts --watch",
    "package": "vsce package",
    "publish": "vsce publish",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "tsx scripts/cleanup.ts dist && pnpm run build && pnpm run create-minimal && pnpm run create-fixtures && tsc -p ./tsconfig.test.json && node ./dist/test/e2e/runE2ETest.js",
    "test:full": "tsx scripts/cleanup.ts dist && pnpm run build && pnpm run create-fixtures && tsc -p ./tsconfig.test.json && SKIP_OPTIMIZATION=true node ./dist/test/e2e/runE2ETest.js",
    "test:minimal": "pnpm test",
    "test:clean": "tsx scripts/cleanup.ts .vscode-test/minimal-extension .vscode-test/user-data-isolated .vscode-test/user-data-dev",
    "create-minimal": "tsx scripts/create-minimal-extension.ts",
    "create-fixtures": "tsx scripts/create-test-fixtures.ts",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@stylistic/eslint-plugin": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "^1.102.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.1",
    "esbuild": "^0.25.12",
    "eslint": "^9.31.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-mocha": "^11.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^3.0.1",
    "fast-glob": "^3.3.2",
    "mocha": "^11.7.1",
    "prettier": "^3.6.2",
    "sinon": "^19.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.46.3"
  }
}
