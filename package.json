{
  "name": "file-insights",
  "displayName": "File Insights",
  "description": "A lightweight VS Code extension that displays file size in the status bar with automatic formatting for bytes, KB, MB, and GB. Features streamlined architecture and minimal resource usage.",
  "version": "2.0.0",
  "license": "MIT",
  "publisher": "VijayGangatharan",
  "icon": "logo.png",
  "author": {
    "name": "Vijay Gangatharan",
    "email": "vijayanand431@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vijay431/file-insights.git"
  },
  "bugs": {
    "url": "https://github.com/Vijay431/file-insights/issues"
  },
  "homepage": "https://github.com/Vijay431/file-insights#readme",
  "keywords": [
    "file",
    "size",
    "status bar",
    "lightweight",
    "formatter"
  ],
  "categories": [
    "Other"
  ],
  "engines": {
    "node": ">=16.0.0 <25.0.0",
    "vscode": "^1.102.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "fileInsights.enable",
        "title": "File Insights: Enable",
        "category": "File Insights"
      },
      {
        "command": "fileInsights.disable",
        "title": "File Insights: Disable",
        "category": "File Insights"
      }
    ],
    "configuration": {
      "title": "File Insights",
      "properties": {
        "fileInsights.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable File Insights extension"
        },
        "fileInsights.displayFormat": {
          "type": "string",
          "enum": [
            "auto",
            "bytes",
            "kb",
            "mb",
            "gb"
          ],
          "default": "auto",
          "description": "Format for displaying file sizes",
          "enumDescriptions": [
            "Automatically choose the best format",
            "Always show in bytes",
            "Always show in kilobytes",
            "Always show in megabytes",
            "Always show in gigabytes"
          ]
        }
      }
    }
  },
  "vsce": {
    "baseImageUrl": "./logo.png",
    "dependencies": true,
    "yarn": false
  },
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "tsx esbuild.config.ts --production",
    "build": "tsx esbuild.config.ts",
    "watch": "tsx esbuild.config.ts --watch",
    "package": "vsce package",
    "publish": "vsce publish",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "rm -rf dist && npm run build && npm run create-minimal && npm run create-fixtures && tsc -p ./tsconfig.test.json && node ./dist/test/e2e/runE2ETest.js",
    "test:full": "rm -rf dist && npm run build && npm run create-fixtures && tsc -p ./tsconfig.test.json && SKIP_OPTIMIZATION=true node ./dist/test/e2e/runE2ETest.js",
    "test:minimal": "npm test",
    "test:clean": "rm -rf .vscode-test/minimal-extension .vscode-test/user-data-isolated .vscode-test/user-data-dev",
    "create-minimal": "tsx scripts/create-minimal-extension.ts",
    "create-fixtures": "tsx scripts/create-test-fixtures.ts",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@stylistic/eslint-plugin": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^16.18.126",
    "@types/vscode": "^1.102.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.1",
    "esbuild": "^0.25.8",
    "eslint": "^9.31.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-mocha": "^11.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^3.0.1",
    "fast-glob": "^3.3.2",
    "mocha": "^11.7.1",
    "picocolors": "^1.1.1",
    "prettier": "^3.6.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.46.2"
  }
}
